{
  "name": "unity-asset-reference-mcp",
  "version": "0.3.0",
  "type": "module",
  "description": "Index a Unity project's assets into a reusable SQLite reference graph — impact analysis, unused-asset detection, dependency tracing, and an MCP server + web viewer. Unity-only.",
  "keywords": [
    "unity",
    "mcp",
    "model-context-protocol",
    "addressables",
    "asset",
    "dependency-graph",
    "unused-assets",
    "impact-analysis",
    "gamedev"
  ],
  "license": "MIT",
  "author": "JVinceW",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JVinceW/uasset-reference-memory-mcp.git"
  },
  "homepage": "https://github.com/JVinceW/uasset-reference-memory-mcp#readme",
  "bugs": {
    "url": "https://github.com/JVinceW/uasset-reference-memory-mcp/issues"
  },
  "bin": {
    "unity-asset-reference-mcp": "dist/mcp/server.js",
    "unity-asset-reference-mcp-index": "dist/cli/main.js",
    "unity-asset-reference-mcp-web": "dist/web/server.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && node scripts/copy-public.mjs",
    "web": "node dist/web/server.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "cytoscape": "^3.34.0",
    "sql.js": "^1.14.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "zod": "^4.4.3"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.21.5": true
  }
}
